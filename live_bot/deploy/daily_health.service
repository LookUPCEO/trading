[Unit]
Description=Daily data-asset health report
After=network.target

[Service]
Type=oneshot
User=bot
Group=bot
WorkingDirectory=/opt/bot
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/bot
ExecStart=/opt/bot/.venv/bin/python /opt/bot/tools/daily_health_report.py \
    --symbols BTCUSDT ETHUSDT
